# ============================================
# GitHub Actions CI/CD - Переменные окружения
# ============================================
# Скопируйте этот файл в .env и заполните значения
# НИКОГДА не коммитьте .env в репозиторий!

# ============================================
# БАЗА ДАННЫХ (для тестов)
# ============================================
DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=test_db
DB_USERNAME=test_user
DB_PASSWORD=test_password

# ============================================
# TELEGRAM (для уведомлений)
# ============================================
# Создать бота: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# СЕРВЕР (для SSH деплоя)
# ============================================
SERVER_HOST=your.server.com
SERVER_USER=deploy
SERVER_PATH=/var/www/soyzchernobilkurgan.local
SERVER_PORT=22

# ============================================
# FTP (альтернатива SSH)
# ============================================
FTP_SERVER=ftp.yourserver.com
FTP_USERNAME=your_ftp_username
FTP_PASSWORD=your_ftp_password
